# MongoDB Connection
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# Optional comma-separated emails that become admins when registered normally
ADMIN_EMAILS=admin@example.com

# Optional key required by /api/auth/register-admin after the first admin exists
ADMIN_SETUP_KEY=change_this_admin_setup_key

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Server Port
PORT=5000
